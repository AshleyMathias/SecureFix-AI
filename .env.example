# ─────────────────────────────────────────────────────────────────────────────
# SecureFix AI — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to VCS.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SecureFix AI
APP_VERSION=1.0.0
ENVIRONMENT=development        # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json                # json | text

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with: repo, pull_requests, security_events scopes
GITHUB_TOKEN=ghp_your_token_here

# Optional: HMAC secret configured on your GitHub webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

GIT_COMMITTER_NAME=SecureFix AI
GIT_COMMITTER_EMAIL=securefix-ai@noreply.github.com

# ── LLM ───────────────────────────────────────────────────────────────────────
# Switch between providers without code changes:
LLM_PROVIDER=openai            # openai | anthropic

# OpenAI
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# Anthropic (activate by setting LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.1
ANTHROPIC_MAX_TOKENS=4096

# ── Scanning ──────────────────────────────────────────────────────────────────
ENABLE_NPM_AUDIT=true
ENABLE_PIP_AUDIT=true
ENABLE_SAFETY=true
ENABLE_OSV=true
SCAN_TIMEOUT_SECONDS=120

# ── Patching ──────────────────────────────────────────────────────────────────
PATCH_BRANCH_PREFIX=securefix/
MAX_VULNERABILITIES_PER_RUN=20
SKIP_BREAKING_CHANGES=false
PR_DRAFT=false
PR_LABELS=security,automated,securefix-ai
AUTO_MERGE_PR=false

# ── Testing ───────────────────────────────────────────────────────────────────
TEST_TIMEOUT_SECONDS=300
SKIP_TESTS_ON_PATCH=false
ABORT_ON_TEST_FAILURE=true

# ── Repository ────────────────────────────────────────────────────────────────
REPO_CLONE_BASE_DIR=/tmp/securefix_repos
CLEANUP_AFTER_RUN=true
